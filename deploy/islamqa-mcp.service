[Unit]
Description=IslamQA MCP Server (FastMCP streamable-http)
After=network.target

[Service]
Type=simple
User=ovehbe
WorkingDirectory=/home/ovehbe/islamqa
Environment="PATH=/home/ovehbe/islamqa/.venv/bin"
EnvironmentFile=-/home/ovehbe/islamqa/.env
ExecStart=/home/ovehbe/islamqa/.venv/bin/islamqa-mcp --config /home/ovehbe/islamqa/config.yml --transport streamable-http
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
